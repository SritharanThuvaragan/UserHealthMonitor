# .gitignore
# Python virtual environment and caches
.venv/
env/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
Dist/
*.egg-info/
.eggs/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Test / coverage reports
htmlcov/
.coverage
.coverage.*
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# IDE settings
.idea/
.vscode/

# Data directories (large files)
dataset/
*.csv
*.tsv
*.json

# Machine learning models and outputs
*.pkl
ml/models/

# Log files
*.log

# OS generated files
.DS_Store
